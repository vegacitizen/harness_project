{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "korean",
  "model": "sonnet",
  "plansDirectory": ".claude/plans",
  "showClearContextOnPlanAccept": true,
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Bash(*)",
      "Bash(Write-Output *)",
      "Bash(New-Item *)",
      "Bash(Get-Content *)",
      "Bash(Test-Path *)",
      "Bash(Set-Content *)",
      "PowerShell(*)",
      "Bash(Select-String *)"
    ],
    "deny": [
      "Write(~/.claude/**)",
      "Edit(~/.claude/**)",
      "Bash(*~/.claude*)",
      "Bash(git push *)",
      "PowerShell(git push *)"
    ]
  }
}

