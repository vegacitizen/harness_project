# =============================================================================
# default.rules — Codex shell command 승인 규칙
# 환경: Linux (WSL2, x86_64), Shell: bash
# 우선순위: forbidden > prompt > allow
# 겹치는 규칙이 있을 때 더 강한 제한이 항상 우선 적용된다.
# pattern은 argv 토큰 단위 prefix 리스트다.
#   예) ["git", "push"] → "git push origin main" 에 매칭
# =============================================================================


# =============================================================================
# FORBIDDEN — 자동 차단 (절대 실행하지 않음)
# =============================================================================

# git push: 원격 저장소로의 push를 차단한다.
# 실수로 실행하면 공유 히스토리가 바뀌어 팀 전체에 영향을 준다.
# 대안 decision: "prompt"는 확인 기회를 주지만 자동화 파이프라인에서 우회될 수 있어 forbidden이 안전하다.
# match 예시: "git push origin main", "git push --force", "git push -f"
prefix_rule(
  pattern = ["git", "push"],
  decision = "forbidden",
  justification = "원격 저장소에 push하면 공유 히스토리가 변경되어 돌이키기 어렵다. 사용자가 직접 실행해야 한다.",
  match = ["git push origin main", "git push --force", "git push -f"]
)

# rm -rf: 재귀 강제 삭제를 차단한다.
# 경로 실수 하나로 프로젝트 전체 또는 홈 디렉터리가 삭제될 수 있다.
# 대안 decision: "prompt"도 가능하지만 rm -rf는 취소가 불가능하므로 forbidden이 적합하다.
# match 예시: "rm -rf data", "rm -rf ./dist", "rm -rf /home/jamespark"
prefix_rule(
  pattern = ["rm", "-rf"],
  decision = "forbidden",
  justification = "재귀 강제 삭제는 복구 불가능하다. 경로 실수 시 프로젝트 전체가 소실된다.",
  match = ["rm -rf data", "rm -rf ./dist", "rm -rf /home/jamespark"]
)

# Remove-Item -Recurse: PowerShell 재귀 삭제를 차단한다.
# WSL2 환경에서 pwsh 호출 시 적용된다.
# 대안 decision: "prompt" — 단, -Force 없이도 위험하므로 forbidden 유지.
# match 예시: "Remove-Item -Recurse -Force ./dist"
prefix_rule(
  pattern = ["Remove-Item", "-Recurse"],
  decision = "forbidden",
  justification = "PowerShell 재귀 삭제는 rm -rf와 동일한 위험을 가진다.",
  match = ["Remove-Item -Recurse -Force ./dist", "Remove-Item -Recurse C:\\project"]
)

# cat .env: .env 파일 출력을 차단한다.
# 터미널 출력 시 API 키 등이 로그나 화면 캡처에 노출될 수 있다.
# allow 규칙 ["cat"] 보다 forbidden이 우선 적용된다 (forbidden > allow).
# match 예시: "cat .env", "cat .env.local", "cat .env.production"
prefix_rule(
  pattern = ["cat", ".env"],
  decision = "forbidden",
  justification = ".env 파일에는 API 키·비밀번호가 포함될 수 있어 출력 자체가 유출 위험이다.",
  match = ["cat .env"]
)

prefix_rule(
  pattern = ["cat", ".env.local"],
  decision = "forbidden",
  justification = ".env.local에는 로컬 환경 인증 정보가 포함될 수 있다.",
  match = ["cat .env.local"]
)

prefix_rule(
  pattern = ["cat", ".env.production"],
  decision = "forbidden",
  justification = ".env.production에는 운영 환경 인증 정보가 포함될 수 있다.",
  match = ["cat .env.production"]
)

# sudo systemctl: 시스템 서비스 제어를 차단한다.
# 프로젝트 스코프 밖이며 운영 환경 전체에 영향을 줄 수 있다.
# 대안 decision: 없음 — 프로젝트 내 작업에 시스템 서비스 제어는 불필요하다.
# match 예시: "sudo systemctl stop nginx", "sudo systemctl disable sshd"
prefix_rule(
  pattern = ["sudo", "systemctl"],
  decision = "forbidden",
  justification = "시스템 서비스 제어는 프로젝트 스코프 밖이며 운영 환경에 영향을 준다.",
  match = ["sudo systemctl stop nginx", "sudo systemctl disable sshd"]
)

# sudo apt: 시스템 패키지 설치·제거를 차단한다.
# 다른 프로젝트나 시스템 환경을 변경할 수 있다.
# match 예시: "sudo apt remove python3", "sudo apt purge git"
prefix_rule(
  pattern = ["sudo", "apt"],
  decision = "forbidden",
  justification = "시스템 패키지 변경은 프로젝트 스코프 밖이며 다른 환경에 영향을 준다.",
  match = ["sudo apt remove python3", "sudo apt purge git"]
)

# chmod -R: 재귀 권한 변경을 차단한다.
# 시스템 파일 접근 구조를 파괴하거나 보안 취약점을 만들 수 있다.
# match 예시: "chmod -R 777 /", "chmod -R 777 /etc"
prefix_rule(
  pattern = ["chmod", "-R"],
  decision = "forbidden",
  justification = "재귀 권한 변경은 시스템 보안 구조를 파괴할 수 있다.",
  match = ["chmod -R 777 /", "chmod -R 777 /etc"]
)

# chown -R: 재귀 소유권 변경을 차단한다.
# match 예시: "chown -R root /home", "chown -R user /etc"
prefix_rule(
  pattern = ["chown", "-R"],
  decision = "forbidden",
  justification = "소유권 일괄 변경은 시스템 파일 접근 구조를 파괴할 수 있다.",
  match = ["chown -R root /home", "chown -R user /etc"]
)


# =============================================================================
# PROMPT — 사용자 확인 필요 (자동 실행 금지)
# =============================================================================

# git commit: 커밋은 히스토리를 변경하므로 메시지와 파일 범위를 확인해야 한다.
# 대안 decision: "allow"는 원치 않는 커밋을 자동 생성할 수 있어 부적합.
# match 예시: "git commit -m 'fix bug'", "git commit --amend"
prefix_rule(
  pattern = ["git", "commit"],
  decision = "prompt",
  justification = "커밋은 프로젝트 히스토리를 변경한다. 메시지와 포함 파일을 사용자가 검토해야 한다.",
  match = ["git commit -m 'fix bug'", "git commit --amend"]
)

# git reset: 스테이지 또는 히스토리를 되돌린다. --hard는 작업 내용을 영구 삭제한다.
# 대안 decision: "forbidden"은 너무 강함 — 개발 중 자주 필요한 명령이므로 prompt가 적합.
# match 예시: "git reset HEAD~1", "git reset --hard origin/main"
prefix_rule(
  pattern = ["git", "reset"],
  decision = "prompt",
  justification = "reset은 작업 내용을 잃을 수 있다. --hard 옵션은 복구가 불가능하다.",
  match = ["git reset HEAD~1", "git reset --hard origin/main"]
)

# git clean: 미추적 파일을 영구 삭제한다.
# match 예시: "git clean -fd", "git clean -fdx"
prefix_rule(
  pattern = ["git", "clean"],
  decision = "prompt",
  justification = "미추적 파일을 영구 삭제한다. 실수로 실행하면 작업 중인 파일이 사라진다.",
  match = ["git clean -fd", "git clean -fdx"]
)

# pip install: Python 패키지를 설치한다. 가상환경 활성화 여부 확인이 필요하다.
# 대안 decision: "allow"로 두면 불필요한 패키지가 자동 설치될 수 있다.
# match 예시: "pip install requests", "pip install -r requirements.txt"
prefix_rule(
  pattern = ["pip", "install"],
  decision = "prompt",
  justification = "패키지 설치는 의존성 트리를 바꾼다. 가상환경 활성화 여부도 확인이 필요하다.",
  match = ["pip install requests", "pip install -r requirements.txt"]
)

# npm install: node_modules를 변경하고 lock 파일에 영향을 준다.
# 대안 decision: "allow"는 예상치 못한 버전 충돌을 유발할 수 있다.
# match 예시: "npm install", "npm install lodash", "npm install --save-dev jest"
prefix_rule(
  pattern = ["npm", "install"],
  decision = "prompt",
  justification = "의존성 변경은 lock 파일을 바꾸며 예상치 못한 버전 충돌이 생길 수 있다.",
  match = ["npm install", "npm install lodash", "npm install --save-dev jest"]
)

# curl: 외부 서버에 요청을 보내거나 파일을 내려받는다.
# 대안 decision: "forbidden"은 너무 강함 — 개발 중 API 테스트에 필요하므로 prompt 유지.
# match 예시: "curl https://example.com", "curl -O https://example.com/file.tar.gz"
prefix_rule(
  pattern = ["curl"],
  decision = "prompt",
  justification = "외부 서버에 요청을 보내거나 파일을 내려받는다. 실행 전 URL 확인이 필요하다.",
  match = ["curl https://example.com", "curl -O https://example.com/file.tar.gz"]
)

# wget: 외부에서 파일을 내려받는다.
# match 예시: "wget https://example.com/script.sh"
prefix_rule(
  pattern = ["wget"],
  decision = "prompt",
  justification = "외부에서 파일을 내려받는다. 출처 확인 없이 실행하면 악성 파일이 유입될 수 있다.",
  match = ["wget https://example.com/script.sh"]
)


# =============================================================================
# ALLOW — 자동 허용 (안전한 읽기·검색·테스트 명령)
# =============================================================================

# ls: 디렉터리 내용을 나열하는 읽기 전용 명령이다.
# 대안 decision: "prompt"는 탐색마다 확인을 요구해 작업 흐름을 방해한다.
# match 예시: "ls", "ls -la", "ls -lh .codex/"
prefix_rule(
  pattern = ["ls"],
  decision = "allow",
  justification = "디렉터리 내용을 나열하는 읽기 전용 명령이다. 부작용이 없다.",
  match = ["ls", "ls -la", "ls -lh .codex/"]
)

# pwd: 현재 작업 경로를 출력하는 읽기 전용 명령이다.
prefix_rule(
  pattern = ["pwd"],
  decision = "allow",
  justification = "현재 작업 디렉터리를 출력하는 읽기 전용 명령이다.",
  match = ["pwd"]
)

# cat: 파일 내용을 출력한다. (secret 파일은 위의 forbidden 규칙이 우선 적용된다.)
# 대안 decision: "prompt"는 파일 열람마다 확인을 요구해 불편하다.
# match 예시: "cat index.html", "cat AGENTS.md"
prefix_rule(
  pattern = ["cat"],
  decision = "allow",
  justification = "파일 내용을 출력하는 읽기 전용 명령이다. secret 파일은 별도 forbidden 규칙이 우선 적용된다.",
  match = ["cat index.html", "cat AGENTS.md", "cat .codex/config.toml"]
)

# head/tail: 파일 앞뒤 일부를 출력하는 읽기 전용 명령이다.
prefix_rule(
  pattern = ["head"],
  decision = "allow",
  justification = "파일 앞부분만 출력하는 읽기 전용 명령이다.",
  match = ["head -20 index.html", "head AGENTS.md"]
)

prefix_rule(
  pattern = ["tail"],
  decision = "allow",
  justification = "파일 끝부분만 출력하는 읽기 전용 명령이다. 로그 확인에도 자주 쓰인다.",
  match = ["tail -50 index.html", "tail -f server.log"]
)

# rg: ripgrep 패턴 검색 도구. 읽기 전용이다.
prefix_rule(
  pattern = ["rg"],
  decision = "allow",
  justification = "ripgrep은 프로젝트 내 패턴 검색용 읽기 전용 도구다.",
  match = ["rg 'city-card' index.html", "rg 'TODO'"]
)

# grep: 파일 내 패턴 검색. 읽기 전용이다.
prefix_rule(
  pattern = ["grep"],
  decision = "allow",
  justification = "파일 내 패턴을 검색하는 읽기 전용 명령이다.",
  match = ["grep -r 'function' .", "grep 'error' server.log"]
)

# find: 파일·디렉터리 탐색. 읽기 전용이다. (-delete 옵션은 sandbox_mode가 제한한다.)
prefix_rule(
  pattern = ["find"],
  decision = "allow",
  justification = "파일·디렉터리를 탐색하는 읽기 전용 명령이다.",
  match = ["find . -name '*.html'", "find .codex -type f"]
)

# PowerShell 읽기·탐색 (WSL2 환경에서 pwsh 호출 시 적용)
prefix_rule(
  pattern = ["Get-ChildItem"],
  decision = "allow",
  justification = "PowerShell의 ls 대응 명령. 디렉터리 내용을 나열하는 읽기 전용 명령이다.",
  match = ["Get-ChildItem .", "Get-ChildItem -Recurse"]
)

prefix_rule(
  pattern = ["Get-Location"],
  decision = "allow",
  justification = "PowerShell의 pwd 대응 명령. 현재 경로를 출력하는 읽기 전용 명령이다.",
  match = ["Get-Location"]
)

prefix_rule(
  pattern = ["Get-Content"],
  decision = "allow",
  justification = "PowerShell의 cat 대응 명령. 파일 내용을 출력하는 읽기 전용 명령이다.",
  match = ["Get-Content index.html", "Get-Content AGENTS.md"]
)

prefix_rule(
  pattern = ["Select-String"],
  decision = "allow",
  justification = "PowerShell의 grep 대응 명령. 파일 내 패턴을 검색하는 읽기 전용 명령이다.",
  match = ["Select-String -Pattern 'TODO' -Path *.html"]
)

# git 조회: 저장소 상태 확인. 수정 없음.
prefix_rule(
  pattern = ["git", "status"],
  decision = "allow",
  justification = "작업 트리의 현재 상태를 확인하는 읽기 전용 명령이다.",
  match = ["git status", "git status -s"]
)

prefix_rule(
  pattern = ["git", "diff"],
  decision = "allow",
  justification = "변경 내용을 비교하는 읽기 전용 명령이다.",
  match = ["git diff", "git diff HEAD", "git diff --staged"]
)

prefix_rule(
  pattern = ["git", "log"],
  decision = "allow",
  justification = "커밋 히스토리를 조회하는 읽기 전용 명령이다.",
  match = ["git log", "git log --oneline -10"]
)

# Python 실행 및 테스트
prefix_rule(
  pattern = ["python3"],
  decision = "allow",
  justification = "프로젝트 내 Python 스크립트 실행 및 로컬 서버 구동에 사용한다.",
  match = ["python3 -m http.server 8000", "python3 script.py"]
)

prefix_rule(
  pattern = ["python"],
  decision = "allow",
  justification = "python3의 별칭. 프로젝트 내 스크립트 실행 및 테스트에 사용한다.",
  match = ["python -m pytest", "python main.py"]
)

prefix_rule(
  pattern = ["pytest"],
  decision = "allow",
  justification = "Python 테스트 실행 도구. 프로젝트 내 테스트 파일을 탐색하고 실행한다.",
  match = ["pytest", "pytest -q", "pytest tests/"]
)

# Node.js 테스트 및 빌드
# 대안 decision: "prompt"는 반복 실행 시 불편하다. 빌드·테스트는 읽기에 가까운 안전 작업이다.
prefix_rule(
  pattern = ["npm", "test"],
  decision = "allow",
  justification = "package.json에 정의된 테스트 스크립트를 실행한다.",
  match = ["npm test", "npm test -- --watch"]
)

prefix_rule(
  pattern = ["npm", "run", "lint"],
  decision = "allow",
  justification = "코드 스타일 검사를 실행한다.",
  match = ["npm run lint"]
)

prefix_rule(
  pattern = ["npm", "run", "build"],
  decision = "allow",
  justification = "프로젝트 빌드 스크립트를 실행한다. 출력물은 프로젝트 내부에 생성된다.",
  match = ["npm run build"]
)

# 파일·폴더 생성 (sandbox_mode = workspace-write 가 프로젝트 밖 생성을 제한한다.)
prefix_rule(
  pattern = ["mkdir"],
  decision = "allow",
  justification = "새 디렉터리를 생성한다. sandbox_mode가 workspace-write이므로 프로젝트 밖 생성은 이미 제한된다.",
  match = ["mkdir .codex/rules", "mkdir -p assets/images"]
)

prefix_rule(
  pattern = ["touch"],
  decision = "allow",
  justification = "빈 파일을 생성하거나 타임스탬프를 갱신한다.",
  match = ["touch index.html", "touch .codex/rules/default.rules"]
)

prefix_rule(
  pattern = ["New-Item"],
  decision = "allow",
  justification = "PowerShell의 파일·폴더 생성 명령이다.",
  match = ["New-Item -ItemType Directory .codex", "New-Item -ItemType File README.md"]
)

# 안전한 패치·수정 적용
# 대안 decision: "prompt" — 단, diff 기반이므로 의도된 변경만 반영되어 allow가 적합하다.
prefix_rule(
  pattern = ["apply_patch"],
  decision = "allow",
  justification = "Codex 내장 패치 적용 도구. 명시적 diff 기반으로만 변경하므로 예측 가능하다.",
  match = ["apply_patch '*** index.html ...'"]
)

prefix_rule(
  pattern = ["git", "apply"],
  decision = "allow",
  justification = "diff 파일을 현재 워크트리에 적용한다. 내용이 명시적이어서 예측 가능한 변경이다.",
  match = ["git apply fix.patch", "git apply --check fix.patch"]
)

prefix_rule(
  pattern = ["patch"],
  decision = "allow",
  justification = "표준 Unix 패치 도구. diff 파일에 정의된 변경만 적용한다.",
  match = ["patch -p1 < fix.patch", "patch index.html < fix.patch"]
)
